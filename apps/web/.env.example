DATABASE_URL=postgresql://<DB_USER>@localhost:5432/ielts_dev

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required. Signs JWT session tokens — prevents tampering.
# Generate a secure value with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://your-app.vercel.app

# ── Google OAuth (for "Sign in with Google") ──────────────────────────────────
# Required if you want users to log in with their Gmail account.
#
# Why: Next.js (NextAuth) acts as an OAuth client. Google needs to know which
# app is requesting access and where to send the user back after they approve.
# Without these credentials Google will reject the sign-in request entirely.
#
# How to get them (free, ~3 min):
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create project (or reuse existing)
#   3. "Create Credentials" → OAuth 2.0 Client ID → Web application
#   4. Add authorised redirect URI:
#        http://localhost:3000/api/auth/callback/google   (local dev)
#        https://yourdomain.com/api/auth/callback/google (production)
#   5. Copy Client ID and Client Secret below.
#
# Leave blank to disable Google sign-in (admin credentials login still works).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── AI Provider (priority: Anthropic → OpenRouter → Ollama) ──────────────────

# Option A: Anthropic Claude (recommended — best quality for IELTS scoring)
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001        # fast tasks (vocab, gen, etc.)
ANTHROPIC_SCORING_MODEL=claude-sonnet-4-6         # IELTS scoring & evaluation

# Option B: OpenRouter (free-tier models, unreliable rate limits)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-12b-it:free

# Option C: Local Ollama (default for local dev, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen2.5-coder:7b

# Set to 'false' to disable AI features and show amber banner.
NEXT_PUBLIC_OLLAMA_ENABLED=true

OLLAMA_DEBUG=false

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional. Leave blank to disable transactional emails (account activation, etc.)
#
# How to get a key (free tier: 3,000 emails/month):
#   1. Go to https://resend.com → create account → API Keys → Create API Key
#   2. Add and verify your sending domain under Domains
#   3. Set EMAIL_FROM to a "From" address on that domain
#
RESEND_API_KEY=
EMAIL_FROM=IELTS Accelerator <noreply@yourdomain.com>

# ── Sentry error monitoring ───────────────────────────────────────────────────
# Optional. Leave blank to disable Sentry — no errors will be captured.
#
# How to set up (free Developer plan — no credit card):
#   1. Go to https://sentry.io → New project → Next.js
#   2. Copy the DSN from the setup page
#   3. Set NEXT_PUBLIC_SENTRY_DSN below to enable error tracking
#
# For source map uploads (better stack traces in production):
#   4. Sentry → Settings → Auth Tokens → Create token
#   5. Fill in SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
#
# Enable:  set NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Disable: leave NEXT_PUBLIC_SENTRY_DSN blank or remove it
NEXT_PUBLIC_SENTRY_DSN=

# Optional — only needed for source map uploads (improves stack traces)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
