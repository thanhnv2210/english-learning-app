DATABASE_URL=postgresql://<DB_USER>@localhost:5432/ielts_dev
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen2.5-coder:7b

# Set to 'false' to disable AI features (e.g. in GitHub Codespaces without local Ollama).
# In Codespaces: run Ollama locally, expose via `ngrok http 11434`, then set OLLAMA_BASE_URL
# to the ngrok HTTPS URL and flip this back to 'true'.
NEXT_PUBLIC_OLLAMA_ENABLED=true
