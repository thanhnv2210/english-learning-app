DATABASE_URL=postgresql://<DB_USER>@localhost:5432/ielts_dev

# ── AI Provider (choose one) ──────────────────────────────────────────────────

# Option A: OpenRouter (recommended for deployment)
# Get your key at openrouter.ai — free tier available
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Option B: Local Ollama (default for local dev)
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen2.5-coder:7b

# Set to 'false' to disable AI features and show amber banner.
# Set to 'true' when using either OpenRouter or Ollama.
NEXT_PUBLIC_OLLAMA_ENABLED=true

OLLAMA_DEBUG=false
