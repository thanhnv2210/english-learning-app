{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:clean": "rm -rf .next && next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:seed:domains": "dotenv -e .env.local -- tsx src/lib/db/seeds/writing-domains.ts",
    "db:seed:vocabulary": "dotenv -e .env.local -- tsx src/lib/db/seeds/vocabulary-words.ts",
    "db:seed:speaking-topics": "dotenv -e .env.local -- tsx src/lib/db/seeds/speaking-topics.ts"
  },
  "dependencies": {
    "ai": "^4",
    "drizzle-orm": "^0.45.2",
    "next": "^15",
    "ollama-ai-provider": "^1.2.0",
    "postgres": "^3.4.9",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
