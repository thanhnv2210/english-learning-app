{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:clean": "rm -rf .next && next dev --turbo",
    "dev:log": "mkdir -p logs && next dev --turbo 2>&1 | tee -a logs/$(date +%Y-%m-%d).log",
    "dev:clean:log": "rm -rf .next && mkdir -p logs && next dev --turbo 2>&1 | tee -a logs/$(date +%Y-%m-%d).log",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:set-password": "dotenv -e .env.local -- tsx src/lib/db/seeds/set-password.ts",
    "db:seed:domains": "dotenv -e .env.local -- tsx src/lib/db/seeds/writing-domains.ts",
    "db:seed:vocabulary": "dotenv -e .env.local -- tsx src/lib/db/seeds/vocabulary-words.ts",
    "db:seed:speaking-topics": "dotenv -e .env.local -- tsx src/lib/db/seeds/speaking-topics.ts",
    "db:seed:speaking-part2-topics": "dotenv -e .env.local -- tsx src/lib/db/seeds/speaking-part2-topics.ts",
    "db:seed:collocations": "dotenv -e .env.local -- tsx src/lib/db/seeds/collocations.ts",
    "db:seed:idioms": "dotenv -e .env.local -- tsx src/lib/db/seeds/idioms.ts",
    "db:seed:comparisons": "dotenv -e .env.local -- tsx src/lib/db/seeds/comparisons.ts",
    "db:backfill:word-types": "dotenv -e .env.local -- tsx src/lib/db/seeds/backfill-word-types.ts",
    "db:seed:projects": "dotenv -e .env.local -- tsx src/lib/db/seeds/projects.ts",
    "db:seed:vocab-banks": "dotenv -e .env.local -- tsx src/lib/db/seeds/vocab-banks.ts",
    "db:seed:grammar-traps": "dotenv -e .env.local -- tsx src/lib/db/seeds/grammar-traps.ts",
    "db:seed:speaking-phrases": "dotenv -e .env.local -- tsx src/lib/db/seeds/speaking-phrases.ts",
    "db:seed:word-pairs": "dotenv -e .env.local -- tsx src/lib/db/seeds/word-pairs.ts",
    "db:seed:drill-texts": "dotenv -e .env.local -- tsx src/lib/db/seeds/drill-texts.ts",
    "db:seed:ielts-results": "dotenv -e .env.local -- tsx src/lib/db/seeds/ielts-results.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.51.0",
    "ai": "^4",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "next": "^15",
    "next-auth": "5.0.0-beta.31",
    "ollama-ai-provider": "^1.2.0",
    "postgres": "^3.4.9",
    "react": "^19",
    "react-dom": "^19",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
